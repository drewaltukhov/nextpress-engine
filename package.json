{
  "name": "nextpress",
  "version": "1.6.2",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "predev": "npm run plugins:discover",
    "dev": "next dev",
    "dev:lean": "NODE_OPTIONS=--max-old-space-size=4096 next dev",
    "prebuild": "npm run plugins:discover && tsx scripts/migrate-on-build.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "plugins:discover": "tsx scripts/plugins/discover.ts",
    "migrate": "tsx --env-file-if-exists=.env.local scripts/migrate.ts apply",
    "migrate:plan": "tsx --env-file-if-exists=.env.local scripts/migrate.ts plan",
    "migrate:status": "tsx --env-file-if-exists=.env.local scripts/migrate.ts status",
    "migrate:rollback": "tsx --env-file-if-exists=.env.local scripts/migrate.ts rollback",
    "db:generate": "drizzle-kit generate",
    "db:generate:users": "drizzle-kit generate --config=src/core-plugins/users/drizzle.config.ts",
    "db:generate:logging": "drizzle-kit generate --config=src/core-plugins/logging/drizzle.config.ts",
    "seed:admin": "tsx --env-file-if-exists=.env.local scripts/seed-admin.ts",
    "seed:seo-fixtures": "tsx --env-file-if-exists=.env.local scripts/seed-seo-fixtures.ts",
    "seed:legal-pages": "tsx --env-file-if-exists=.env.local scripts/seed-legal-pages.ts",
    "snapshot:demo": "tsx --env-file-if-exists=.env.local scripts/snapshot-demo.ts",
    "audit:seo": "tsx --env-file-if-exists=.env.local scripts/seo-audit.ts",
    "audit:settings": "tsx scripts/audit-settings-wiring.ts",
    "reset-setup": "tsx --env-file-if-exists=.env.local scripts/reset-setup.ts",
    "logs:prune": "tsx --env-file-if-exists=.env.local scripts/logs-prune.ts",
    "pages:purge-trash": "tsx --env-file-if-exists=.env.local scripts/pages-purge-trash.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@aws-sdk/client-s3": "^3.1046.0",
    "@base-ui/react": "^1.4.1",
    "@codemirror/lang-css": "^6.3.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@libsql/client": "^0.17.3",
    "@measured/puck": "^0.20.2",
    "@node-rs/argon2": "^2.0.2",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-text-align": "^3.23.1",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@types/react-grid-layout": "^1.3.6",
    "@uiw/react-codemirror": "^4.25.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "fflate": "^0.8.2",
    "fumadocs-core": "^16.8.5",
    "fumadocs-mdx": "^14.3.2",
    "fumadocs-ui": "^16.8.5",
    "image-size": "^2.0.2",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^8.0.7",
    "postgres": "^3.4.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-grid-layout": "^1.5.3",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "yet-another-react-lightbox": "^3.32.0",
    "zod": "^3.23.8",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/zxcvbn": "^4.4.5",
    "@vitest/ui": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "next": {
      "postcss": "$postcss"
    },
    "@measured/puck": {
      "uuid": "^11.1.1"
    },
    "esbuild": "^0.25.12"
  }
}
